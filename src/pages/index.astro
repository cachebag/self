---
import Layout from "../layouts/Layout.astro";
import { journalEntries } from "../data/journal";

const base = import.meta.env.BASE_URL;

function formatListDate(iso: string) {
  return new Date(iso + "T12:00:00").toLocaleDateString("en-US", {
    year: "numeric",
    month: "numeric",
    day: "numeric",
  });
}
---

<Layout title="akrm al-hakimi">
  <h1>hello, there!</h1>

  <p>
    my name is akrm (or ace). i'm currently a software engineer at robert bosch llc, where i am on the
    vehicle data solutions team, working on distributed vehicle telemtry. i'm also a senior at wayne state university, where i study computer science.
    my graduation date is december 2026.
  </p>

  <p>
    in my free time i <a href="https://github.com/cachebag" target="_blank" rel="noopener noreferrer">build and maintain</a>
    open source software, watch and play basketball, and spend time with my family.
  </p>

  <hr />

  <h2>journal</h2>
  <p class="section-note">
    <a href={`${base}journal/`}>all posts</a>
  </p>

  <ul class="entry-list">
    {journalEntries.map((e) => (
      <li>
        <a href={`${base}journal/${e.slug}/`}>{e.title}</a>
        <span class="meta">
          <time datetime={e.date}>{formatListDate(e.date)}</time>
        </span>
      </li>
    ))}
  </ul>
</Layout>

<style>
  .section-note {
    color: #888;
    font-size: 0.9rem;
    margin-bottom: 1.25rem;
  }

  .entry-list {
    list-style: none;
    padding-left: 0;
  }

  .entry-list li {
    margin-bottom: 0.85rem;
  }

  .entry-list a {
    font-weight: 500;
  }

  .meta {
    display: block;
    color: #888;
    font-size: 0.9rem;
    margin-top: 0.15rem;
  }
</style>
