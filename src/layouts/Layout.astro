---
export interface Props {
  title: string;
  description?: string;
}

const { title, description = "Personal site" } = Astro.props;

const base = import.meta.env.BASE_URL;

const navItems = [
  { href: `${base}`, label: "home" },
  { href: `${base}journal/`, label: "journal" },
  { href: `${base}work/`, label: "work" },
];

const currentPath = Astro.url.pathname;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">
  </head>
  <body>
    <div class="container">
      <nav>
        {navItems.map((item, i) => (
          <>
            <a
              href={item.href}
              class:list={{ active: currentPath === item.href || (item.href !== base && currentPath.startsWith(item.href)) }}
            >{item.label}</a>{i < navItems.length - 1 && <span class="sep">&bull;</span>}
          </>
        ))}
      </nav>

      <main>
        <slot />
      </main>
    </div>
  </body>
</html>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    background: #1a1a1a;
    color: #d4d4d4;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 14px;
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
  }

  .container {
    max-width: 640px;
    margin: 0 auto;
    padding: 3rem 1.5rem 6rem;
  }

  nav {
    margin-bottom: 2.5rem;
    font-size: 14px;
  }

  nav a {
    color: #d4d4d4;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  nav a:hover,
  nav a.active {
    color: #5cb85c;
  }

  .sep {
    margin: 0 0.5rem;
    color: #888;
  }

  main :global(a) {
    color: #5cb85c;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  main :global(a:hover) {
    color: #7cd67c;
  }

  main :global(a:visited) {
    color: #5cb85c;
  }

  main :global(h1) {
    font-size: 1.4rem;
    font-weight: 600;
    margin-bottom: 1rem;
    line-height: 1.3;
  }

  main :global(h2) {
    font-size: 1.1rem;
    font-weight: 600;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  main :global(h3) {
    font-size: 1rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  main :global(p) {
    margin-bottom: 1rem;
  }

  main :global(ul),
  main :global(ol) {
    margin-bottom: 1rem;
    padding-left: 1.25rem;
  }

  main :global(li) {
    margin-bottom: 0.25rem;
  }

  main :global(code) {
    background: #2a2a2a;
    padding: 0.15rem 0.35rem;
    border-radius: 3px;
    font-size: 0.9em;
  }

  main :global(pre) {
    background: #2a2a2a;
    padding: 1rem;
    border-radius: 4px;
    overflow-x: auto;
    margin-bottom: 1rem;
    font-size: 0.9em;
  }

  main :global(pre code) {
    background: transparent;
    padding: 0;
  }

  main :global(blockquote) {
    border-left: 2px solid #444;
    padding-left: 1rem;
    margin-left: 0;
    margin-bottom: 1rem;
    color: #888;
    font-style: italic;
  }

  main :global(hr) {
    border: none;
    border-top: 1px solid #333;
    margin: 2rem 0;
  }

  main :global(.photo) {
    width: 100%;
    max-width: 480px;
    border: 1px solid #333;
    border-radius: 3px;
    margin-top: 0.5rem;
    display: block;
    margin-left: auto;
    margin-right: auto;
  }

  @media (max-width: 480px) {
    .container {
      padding: 2rem 1.25rem 4rem;
    }
  }
</style>
