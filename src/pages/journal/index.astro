---
import Layout from "../../layouts/Layout.astro";
import { journalEntries } from "../../data/journal";

const base = import.meta.env.BASE_URL;

function formatListDate(iso: string) {
  return new Date(iso + "T12:00:00").toLocaleDateString("en-US", {
    year: "numeric",
    month: "numeric",
    day: "numeric",
  });
}
---

<Layout
  title="journal — akrm al-hakimi"
  description="Updates on projects, work, and side interests."
>
  <h1>journal</h1>
  <p class="lede">short posts; newest first.</p>

  <ul class="entry-list">
    {journalEntries.map((e) => (
      <li>
        <a href={`${base}journal/${e.slug}/`}>{e.title}</a>
        <span class="meta">
          <time datetime={e.date}>{formatListDate(e.date)}</time>
          {" — "}
          {e.description}
        </span>
      </li>
    ))}
  </ul>
</Layout>

<style>
  .lede {
    color: #888;
    margin-bottom: 1.5rem;
  }

  .entry-list {
    list-style: none;
    padding-left: 0;
  }

  .entry-list li {
    margin-bottom: 1.15rem;
  }

  .entry-list a {
    font-weight: 500;
  }

  .meta {
    display: block;
    color: #888;
    font-size: 0.9rem;
    margin-top: 0.2rem;
    line-height: 1.5;
  }
</style>
