---
import Layout from "../layouts/Layout.astro";

const projects = [
  {
    name: "nmrs",
    url: "https://github.com/cachebag/nmrs",
    description: "Rust bindings for NetworkManager + Wayland-compatible GUI",
    thumbnail: `${import.meta.env.BASE_URL}/nmrs.png`,
    icons: [`${import.meta.env.BASE_URL}/rs.svg`, `${import.meta.env.BASE_URL}/linux.png`],
    tags: ["rust", "linux", "wayland"]
  },
  {
    name: "rlox",
    url: "https://github.com/cachebag/rlox",
    description: "Fully functional language interpreter built in Rust, inspired by Robert Nystrom's Crafting Interpreters.",
    thumbnail: `${import.meta.env.BASE_URL}/mountain.png`,
    icons: [`${import.meta.env.BASE_URL}/rs.svg`],
    tags: ["rust", "interpreters"]
  }
];
---

<Layout title="Projects | Akrm Al-Hakimi">
  <h1 class="page-title">Projects</h1>

  <div class="projects-list">
    {projects.map(project => (
      <a href={project.url} target="_blank" rel="noopener noreferrer" class="project-card card">
        {project.thumbnail && (
          <div class="project-image-wrapper">
            <img src={project.thumbnail} alt={project.name} class="project-image" />
          </div>
        )}
        <div class="project-content">
          <div class="project-header">
            <h2 class="project-title">{project.name}</h2>
            <span class="project-arrow">↗</span>
          </div>
          <p class="project-description">{project.description}</p>
          <div class="project-footer">
            <div class="project-tags">
              {project.tags?.map((tag, index) => (
                <>
                  <span class="tag">{tag}</span>
                  {index < project.tags.length - 1 && <span class="tag-separator">•</span>}
                </>
              ))}
            </div>
            <div class="project-icons">
              {project.icons?.map(icon => (
                <img src={icon} alt="tech" class="project-icon" />
              ))}
            </div>
          </div>
        </div>
      </a>
    ))}
  </div>
</Layout>

<style>
  .projects-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    padding: 0;
    color: var(--text-bright);
    text-decoration: none;
    transition: border-color 0.2s ease;
  }

  .project-card:hover {
    border-color: var(--accent);
  }

  .project-image-wrapper {
    width: 100%;
    aspect-ratio: 16/9;
    overflow: hidden;
    background: var(--bg-surface);
  }

  .project-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .project-card:hover .project-image {
    transform: scale(1.02);
  }

  .project-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .project-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }

  .project-title {
    font-size: 1.75rem;
    font-weight: 600;
    color: var(--text-bright);
    letter-spacing: -0.5px;
    text-decoration: underline;
    text-decoration-color: var(--text-muted);
  }

  .project-arrow {
    font-size: 1.1rem;
    color: var(--text-muted);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .project-card:hover .project-arrow {
    transform: translate(2px, -2px);
  }

  .project-description {
    font-size: 0.95rem;
    color: var(--text);
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .project-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border);
  }

  .project-tags {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .project-tags .tag {
    color: var(--text-muted);
    background: transparent;
    padding: 0;
    font-size: 0.85rem;
  }

  .tag-separator {
    color: var(--text-muted);
    opacity: 0.5;
  }

  .project-icons {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .project-icon {
    width: 20px;
    height: 20px;
    opacity: 0.7;
    transition: opacity 0.3s ease;
  }

  .project-card:hover .project-icon {
    opacity: 1;
  }
</style>

